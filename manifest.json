{
  "manifest_version": 3,
  "name": "Focus Me",
  "version": "1.0.0",
  "description": "Stay focused by limiting Chrome windows and tabs. Extra windows are redirected as tabs.",
  "permissions": ["windows", "tabs", "storage", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Me",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
